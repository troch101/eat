PROJECT_NAME=MiniCook
ENVIRONMENT=development

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=minicook
POSTGRES_USER=minicook
POSTGRES_PASSWORD=minicook_password
DATABASE_URL=postgresql+psycopg://minicook:minicook_password@postgres:5432/minicook

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=minicook
MINIO_ROOT_PASSWORD=minicook_password
MINIO_BUCKET=minicook-assets

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_API_BASE_URL=http://localhost:8000/api/v1
